(version 1)

(rule "FPGA_F_rule"
	(condition "(A.Type == 'Track' || A.Type == 'Via') && A.intersectsArea('FPGA_ESCAPE') && A.Layer == 'F.Cu'")
	(constraint track_width (min 0.254mm) (opt 0.254mm))
	(constraint via_diameter (min 0.6mm) (opt 0.6mm))
	(constraint hole_size (min 0.3mm) (opt 0.3mm)))

(rule "FPGA_B_rule"
	(condition "(A.Type == 'Track' || A.Type == 'Via') && A.intersectsArea('FPGA_ESCAPE') && A.Layer == 'B.Cu'")
	(constraint track_width (min 0.2mm) (opt 0.6mm))
	(constraint via_diameter (min 0.6mm) (opt 0.6mm))
	(constraint hole_size (min 0.3mm) (opt 0.3mm)))

(rule "Int2_Track_Width_rule"
    (condition "A.Type == 'Track' && A.Layer == 'In2.Cu'")
	(constraint track_width (min 1mm) (opt 2mm)))
